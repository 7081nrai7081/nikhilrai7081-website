# Header rules for Cloudflare Pages / Netlify (ignored by hosts that don't read _headers)

# Security headers — applied site-wide.
# (No Content-Security-Policy: the page relies on inline GTM/AdSense/Clarity/Pixel
#  scripts, so a CSP would need 'unsafe-inline' and add little real protection.)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Static assets — safe to cache long-term.
# CSS/JS are cache-busted via ?v=N, so a new version is a new URL.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

# Serve the web app manifest with the correct content type.
/site.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=604800

# HTML should always revalidate so new deploys appear immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Serve the sitemap as XML (hosts may otherwise default .xml to text/plain).
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=0, must-revalidate
